# HackerOne API credentials (create at hackerone.com → Settings → API Token)
H1_USERNAME=your_h1_username
H1_API_KEY=your_h1_api_key

# Anthropic API key for LLM classification
ANTHROPIC_API_KEY=sk-ant-...

# Optional: GitHub token for higher rate limits on GHSL adapter
GITHUB_TOKEN=ghp_...

# Store path (default: ~/.threat-intel/records)
INTEL_STORE_PATH=~/.threat-intel/records

# Classify batch size (default: 10, reduce if hitting rate limits)
CLASSIFY_BATCH_SIZE=10
